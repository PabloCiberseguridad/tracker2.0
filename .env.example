# ── Supabase ──────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...     # Settings > API > service_role key (¡nunca al cliente!)

# ── Panel de administración ────────────────────────
PANEL_SECRET=una_clave_secreta_larga_y_random

# ── Meta CAPI ─────────────────────────────────────
META_PIXEL_ID=1234567890
META_CAPI_TOKEN=EAAxxxx...      # Gestor de eventos > CAPI > token

# Opcional: para testear sin enviar eventos reales
META_TEST_CODE=TEST12345

# ── URLs de la app (usadas internamente en las APIs) ──
APP_URL=https://tu-proyecto.vercel.app
APP_DOMAIN=tu-proyecto.vercel.app
